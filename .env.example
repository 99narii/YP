# Resend API Key (https://resend.com에서 발급)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# 이메일 설정
EMAIL_FROM=noreply@yourdomain.com  # 발신자 이메일 (Resend에서 도메인 인증 필요, 테스트 시 onboarding@resend.dev 사용 가능)
EMAIL_TO=contact@yourdomain.com     # 문의 내용을 받을 이메일

# Google Sheets Webhook URL (Google Apps Script 웹앱 URL)
GOOGLE_SHEET_WEBHOOK_URL=https://script.google.com/macros/s/xxxxxxxxxxxxx/exec
